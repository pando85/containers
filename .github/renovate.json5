{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'docker:enableMajor',
    'helpers:pinGitHubActionDigests',
    ':automergePr',
    ':dependencyDashboard',
    ':disableRateLimiting',
  ],
  dependencyDashboardTitle: 'Renovate Dashboard',
  customManagers: [
    {
      customType: 'regex',
      description: 'Process Annotations in Dockerfiles',
      managerFilePatterns: [
        '/(^|/)(Dockerfile|docker-bake\\.hcl)$/',
      ],
      matchStrings: [
        '(?<annotation>// renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+).*)\\n\\s*default\\s*=\\s*"(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: '{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}',
      versioningTemplate: '{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}',
    },
  ],
  packageRules: [
    {
      description: 'Release Rules for App Updates',
      addLabels: [
        'app/{{parentDir}}',
      ],
      additionalBranchPrefix: '{{parentDir}}-',
      commitMessageExtra: '( {{currentVersion}} → {{newVersion}} )',
      commitMessageTopic: '{{depName}}',
      matchFileNames: [
        '**/docker-bake.hcl',
        '**/Dockerfile',
      ],
      semanticCommitScope: '{{parentDir}}',
      semanticCommitType: 'release',
    },
    {
      description: 'Auto-merge App Updates',
      matchFileNames: [
        '**/docker-bake.hcl',
      ],
      automerge: true,
      automergeType: 'pr',
      ignoreTests: false,
    },
    {
      description: 'Allowed Ubuntu Version for Base Images',
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        '/ubuntu/',
      ],
      allowedVersions: '/24\\.04|noble(-[0-9]+)?/',
    },
    {
      description: 'Allowed Alpine Version for Base Images',
      matchDatasources: [
        'docker',
      ],
      matchFileNames: [
        '**/Dockerfile',
      ],
      matchPackageNames: [
        '/alpine/',
      ],
      allowedVersions: '/3\\.23/',
    },
    {
      description: 'Allowed Python Version for Base Images',
      matchDatasources: [
        'docker',
      ],
      matchFileNames: [
        '**/Dockerfile',
      ],
      matchPackageNames: [
        '/python/',
      ],
      allowedVersions: '/3\\.13-alpine3\\.23/',
    },
    {
      description: 'Automerge Docker digest updates',
      matchDatasources: [
        'docker',
      ],
      matchUpdateTypes: [
        'digest',
      ],
      branchPrefix: 'renovate/docker-digest-',
      additionalBranchPrefix: '{{depName}}/',
      automerge: true,
      automergeType: 'pr',
    },
    {
      description: 'Digest update commit message',
      matchUpdateTypes: [
        'digest',
      ],
      semanticCommitType: 'chore',
      commitMessageExtra: '({{currentDigestShort}} → {{newDigestShort}})',
      labels: [
        'type/digest',
      ],
    },
    {
      description: 'Label major updates',
      matchUpdateTypes: [
        'major',
      ],
      labels: [
        'type/major',
      ],
      semanticCommitType: 'feat',
      commitMessagePrefix: '{{semanticCommitType}}({{semanticCommitScope}})!:',
      commitMessageExtra: '({{currentVersion}} → {{newVersion}})',
    },
    {
      description: 'Label minor updates',
      matchUpdateTypes: [
        'minor',
      ],
      labels: [
        'type/minor',
      ],
      semanticCommitType: 'feat',
      commitMessageExtra: '({{currentVersion}} → {{newVersion}})',
    },
    {
      description: 'Label patch updates',
      matchUpdateTypes: [
        'patch',
      ],
      labels: [
        'type/patch',
      ],
      semanticCommitType: 'fix',
      commitMessageExtra: '({{currentVersion}} → {{newVersion}})',
    },
    {
      description: 'Auto-merge GitHub Actions',
      matchManagers: [
        'github-actions',
      ],
      automerge: true,
      automergeType: 'pr',
      matchUpdateTypes: [
        'minor',
        'patch',
        'digest',
      ],
      minimumReleaseAge: '3 days',
      ignoreTests: true,
      semanticCommitType: 'ci',
      semanticCommitScope: 'github-action',
      commitMessageTopic: 'action {{depName}}',
    },
    {
      description: 'Auto-merge trusted GitHub Actions',
      matchManagers: [
        'github-actions',
      ],
      matchPackageNames: [
        '/^actions\\//',
        '/^anchore\\//',
        '/^docker\\//',
        '/^renovatebot\\//',
        '/^sigstore\\//',
      ],
      automerge: true,
      automergeType: 'pr',
      matchUpdateTypes: [
        'minor',
        'patch',
        'digest',
      ],
      minimumReleaseAge: '1 minute',
      ignoreTests: true,
    },
    {
      description: 'Docker image commit message',
      matchDatasources: [
        'docker',
      ],
      semanticCommitScope: 'container',
      commitMessageTopic: 'image {{depName}}',
    },
    {
      description: 'GitHub releases commit message',
      matchDatasources: [
        'github-releases',
      ],
      semanticCommitScope: 'github-release',
      commitMessageTopic: 'release {{depName}}',
    },
    {
      description: 'Auto-merge ghcr.io/pando85/ci-runner updates',
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'ghcr.io/pando85/ci-runner',
      ],
      pinDigests: true,
      automerge: true,
      automergeType: 'pr',
    },
  ],
}